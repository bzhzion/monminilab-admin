# Générer un hash bcrypt : python3 -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('votre-mdp'))"
ADMIN_PASSWORD=$2b$12$REMPLACER_PAR_UN_VRAI_HASH_BCRYPT
SECRET_KEY=change-this-to-a-long-random-string

DB_PATH=/data/app.db

MARIADB_HOST=wordpress-db
MARIADB_ROOT_USER=root
MARIADB_ROOT_PASSWORD=supersecret

CF_TOKEN=your-cloudflare-bearer-token
CF_GLOBAL_API_KEY=your-cloudflare-global-api-key
CF_ACCOUNT_EMAIL=your-email@example.com
CF_ACCOUNT_ID=fbfb44c7290b5e2ea9e55daaa79caff7
CF_ZONE_ID=fe915e88c6ef069f294c2e4efbd8154b
CF_TUNNEL_ID=56c83089-b78d-43f1-a456-b5ab3eb5446d

FE_API_KEY=your-forwardemail-api-key

# Cloudflare Access — validation JWT portail client
# CF_TEAM_DOMAIN : sous-domaine de cloudflareaccess.com (ex: "gochu" pour gochu.cloudflareaccess.com)
